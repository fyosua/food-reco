# ─── Required ───────────────────────────────────────
OPENROUTER_API_KEY=***
JWT_SECRET_KEY=change...ring

# ─── Admin seed (first run only) ────────────────────
ADMIN_EMAIL=your@email.com
ADMIN_PASSWORD=your...d

# ─── Optional ───────────────────────────────────────
# Database path (default: data/food_reco.db)
DATABASE_URL=sqlite+aiosqlite:///./data/food_reco.db

# SMTP not configured — email verification is disabled
# All users are auto-verified on registration

# Cloudflare Tunnel (Pi deployment only)
TUNNEL_TOKEN=***