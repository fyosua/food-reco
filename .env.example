# ─── Required ───────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET_KEY=change-this-to-another-random-64-char-string

# ─── Optional ───────────────────────────────────────
# SMTP for email verification (skip for local dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@food.yosuaf.com

# Cloudflare Tunnel (Pi deployment only)
TUNNEL_TOKEN=

# Database path (default: data/food_reco.db)
DATABASE_URL=sqlite+aiosqlite:///./data/food_reco.db